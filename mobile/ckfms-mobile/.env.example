# CKFMS Mobile Environment Configuration
# Copy file này thành .env và điền giá trị thật

# URL của backend API (Spring Boot / Laravel)
# Khi dùng Expo Go với máy thật cùng WiFi → dùng IP máy tính
# VD: EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
